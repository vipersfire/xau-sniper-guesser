# Copy this to .env and fill in your values

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xauusd_sniper

# MT5 (MIFX Ultra Low account)
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=MIFX-UltraLow
MT5_PATH=

# FRED API (free at fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key

# Nasdaq Data Link / Quandl (free tier available)
NASDAQ_API_KEY=your_nasdaq_api_key

# OANDA v20 API (for retail sentiment)
OANDA_API_KEY=your_oanda_api_key
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_ENVIRONMENT=practice

# Telegram bot (optional — for trade alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading
PAPER_TRADING=true
MAX_CONCURRENT_POSITIONS=3
ACCOUNT_BALANCE_OVERRIDE=0

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
