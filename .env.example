# Copy this to .env and fill in your values

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xauusd_sniper

# MT5 (MIFX Ultra Low account)
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=MIFX-UltraLow
MT5_PATH=

# FRED API (free at fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key

# CFTC COT — no API key needed (public ZIP downloads)
COT_BASE_URL=https://www.cftc.gov/dta/zip/deacot{year}.zip
COT_GOLD_CODE=088691

# Telegram bot (optional — for trade alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading
PAPER_TRADING=true
MAX_CONCURRENT_POSITIONS=3
ACCOUNT_BALANCE_OVERRIDE=0

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
